# ═══════════════════════════════════════════════════════════════════════
# Quest UE4 Modloader — .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Build output ──────────────────────────────────────────────────────
modloader/build/
*.so
*.o
*.a
*.obj
*.lib
*.dll
*.dylib
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
.ninja_deps
.ninja_log
build.ninja

# ── Game assets (copyrighted — NEVER commit) ──────────────────────────
PAKS/
PAKS_extracted/

# ── Custom PAKs we built (these are OUR assets, OK to commit) ────────
# paks/ (lowercase) is tracked — contains our custom-built .pak files
# PAKS/ (uppercase) is ignored — contains copyrighted game assets

# ── SDK dump (auto-generated from device, 5400+ files) ───────────────
Current Modloader SDK/

# ── Reference projects (vendored, not ours) ──────────────────────────
RE-UE4SS/

# ── Unreal Engine source (copyrighted — NEVER commit) ───────────────
Unreal Engine For Quest/

# ── sol2 full repo clone (only sol2/include/ is used) ────────────────
modloader/third_party/sol2_repo/

# ── Junk / experimental ──────────────────────────────────────────────
Junk/

# ── Pinball FX VR Patches (huge BDMP database ~7GB) ─────────────────
Pinball FX VR Patches/

# ── Binary analysis extracted data ───────────────────────────────────
extracted/

# ── Installer build artifacts ────────────────────────────────────────
installer_err.txt
installer_out.txt
installer_output.txt

# ── Rust build output ────────────────────────────────────────────────
tools/bindump/target/
installer/target/

# ── Root-level test/diagnostic scripts (personal) ────────────────────
diagnose_mods.py
quick_test.py
test_*.py
verify_mods.py

# ── NDK / SDK local copies ──────────────────────────────────────────
sdks/

# ── Tools exploration scripts (personal) ─────────────────────────────
tools/explore_*.py
tools/ping.py
tools/quick_test.py

# ── Logs & crash dumps ───────────────────────────────────────────────
logs/
*.log
*.tombstone

# ── Local deploy configs (contain device IPs, paths) ─────────────────
_sftp_batch.txt
_sftp_deploy.txt

# ── Test scripts (personal, device-specific) ─────────────────────────
testers/
tools/_*.py
tools/test_*.py
tools/bridge_test.py
tools/raw_*.py
tools/*_probe*.py
tools/probe_*.py
tools/menu_probe*.py
tools/deep_probe.py
tools/*_diag.py
tools/modify_*.py
tools/stress_test.py
tools/launchre4.py
tools/__pycache__/
tools/*.log
tools/extracted_pak/
tools/bin/
tools/repak/

# ── Backup / old version files ───────────────────────────────────────
*_backup.lua
*.bak
*.orig

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/

# ── IDE / Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── APK & signing ────────────────────────────────────────────────────
*.apk
*.idsig
*.keystore

# ── SSH keys (NEVER commit) ──────────────────────────────────────────
*.pem
*.key
id_rsa*
quest_root*

# ── Lua IntelliSense (local config) ──────────────────────────────────
.luarc.json

# ── UE4SS reference doc (large) ──────────────────────────────────────
UE4SS_LUA_API_COMPLETE_REFERENCE.md
